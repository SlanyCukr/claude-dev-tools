{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre_tool_checker.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/evasion_checker.py\"",
            "timeout": 25
          }
        ]
      }
    ]
  }
}
